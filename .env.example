# Google Earth Engine OAuth (User Login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Earth Engine Service Account (App-level Login - Optional)
# If provided, users will not need to log in. The app will authenticate itself.
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_PRIVATE_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
